{
  "version": 2,
  "buildCommand": "cd frontend && npm install && npm run build",
  "devCommand": "npm run dev --prefix frontend",
  "outputDirectory": "frontend/dist",
  "cleanUrls": true,
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/((?!api/|node_modules/|@|.*\\.[a-zA-Z0-9]+$).*)", "destination": "/index.html" }
  ],
  "crons": [
    {
      "path": "/api/admin/update-matches?secret=14e7aa398cca7426c8b96aa5df14e93ee62987ca91b5d641821363e8ba007149&sync=true",
      "schedule": "0 6 * * *"
    }
  ]
}
